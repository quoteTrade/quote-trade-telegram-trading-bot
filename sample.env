TELEGRAM_BOT_TOKEN=your-telegram-bot-token
API_BASE_URL=https://app.quote.trade/api
LIQUIDITY_WS_URL=wss://app.quote.trade/ws/liquidity
LISTEN_KEY_WS_URL=wss://app.quote.trade/ws/listenKey
MODE=paper
# Telegram trading users connect their own Quote.Trade keys with /connectkey.
# The legacy global TRADE_* vars are not used by the session-backed Telegram runtime.
TRADE_API_KEY=
TRADE_API_SECRET=
SIGNING_ALGORITHM=sha256
TELEGRAM_SESSION_ENCRYPTION_KEY=replace-with-a-long-random-value
QUOTE_TRADE_STATE_DIR=.quote-trade
# Reject stale Telegram commands older than this many seconds. Set 0 to disable.
TELEGRAM_MAX_COMMAND_AGE_SECONDS=300
# Pending LLM order drafts expire after this many seconds. Set 0 to disable.
LLM_DRAFT_MAX_AGE_SECONDS=3600
# L2 snapshots older than this are not used for order-trigger decisions. Set 0 to disable.
TRIGGER_MAX_L2_AGE_MS=5000
# Cached L2 snapshots older than this are not replayed to newly subscribed trigger runtimes. Defaults to TRIGGER_MAX_L2_AGE_MS.
PRICE_FEED_MAX_SNAPSHOT_AGE_MS=5000
# Trigger runtimes process every L2 update by default. Set >0 only if you intentionally want per-subscriber throttling.
PRICE_FEED_MIN_TRIGGER_INTERVAL_MS=0
POSITIONS_ENDPOINT=/positions
DEFAULT_PAYMENT_CURRENCY=USD
# Optional LLM strategy planner keys. Prefer env vars over storing raw keys in .quote-trade/llm-config.json.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OVHCLOUD_API_KEY=
AI_ENDPOINT_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
HF_TOKEN=
POLLINATIONS_API_KEY=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=
